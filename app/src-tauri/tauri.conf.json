{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tandem-vpn",
  "version": "0.1.0",
  "identifier": "crypto.etern1ty.tandemvpn",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "tandem-vpn — Zapret",
        "width": 980,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" }
    }
  }
}
